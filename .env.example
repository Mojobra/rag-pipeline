# Copy this file to .env and replace only the API-key placeholders.
# The real .env file is ignored by Git and must never be committed.
# Generation variables are selected by --model; _EMBED variables are selected
# independently by --embed-model.

GOOGLE_API_KEY=<API-KEY>
GEMINI=gemini-3.1-flash-lite
GEMINI_EMBED=gemini-embedding-2

OPENAI_API_KEY=<API-KEY>
OPENAI=gpt-5-mini
OPENAI_EMBED=text-embedding-3-small

ANTHROPIC_API_KEY=<API-KEY>
CLAUDE=claude-sonnet-4-6
# Anthropic has no embedding API; this selects a local Hugging Face model.
CLAUDE_EMBED=sentence-transformers/all-MiniLM-L6-v2
